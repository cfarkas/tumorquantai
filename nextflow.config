manifest {
    name = 'cfarkas/tumorquantai'
    author = 'Carlos Farkas'
    description = 'TumorQuantAI whole-slide cell typing, reporting, and cohort analysis'
    mainScript = 'main.nf'
    nextflowVersion = '>=24.10.0'
    version = '0.4.0'
}

params {
    input_dir = null
    output_dir = null
    sample_sheet = null
    slide_patterns = ['*_L0_rgb.tif', '*_L0_rgb.tiff']
    include = '*'
    exclude = ''
    dry_run = false
    worker_script = null

    container_image = 'carlosfarkas/lazyslide-histoplus@sha256:413bed6b55bc86923321c61453c18ece678da3c125ae44dcbd5f6c3bce7115d4'
    docker_run_options = ''
    docker_shm_size = '2g'
    cpus = 8
    memory = '32 GB'
    time = '120h'
    max_retries = 1
    max_parallel_slides = 1
    continue_on_error = true

    mpp = 0.5
    slide_mpp = null
    tile_px = 840
    overlap = 0.2
    background_fraction = 0.95
    percent_slide = 100.0
    patch_random_seed = 20260709
    max_sampled_patches = 0
    collage = null

    device = 'cuda'
    num_workers = 2
    run_cells_stage = false
    cells_model = 'instanseg'
    cells_batch_size = 4
    celltypes_batch_size = 2
    histoplus_magnification = '20x'
    histoplus_revision = 'cde2eee81af9e39b03802fc33d4f284733b5ee5e'
    histoplus_weight_file = null
    histoplus_weight_sha256 = null
    histoplus_cache_dir = '/home/lazyslide/.cache/histoplus'
    amp = false

    convert_to_pyramidal = true
    pyramidal_tile = 512
    pyramidal_compression = 'lzw'
    pyramidal_jpeg_q = 90

    zoom_size = 2000
    overlay_alpha = 0.35
    overlay_style = 'outline_centroid'
    overlay_outline_width = 2
    overlay_halo_width = 4
    overlay_draw_order = 'small-last'
    cell_marker_radius = 3
    figure_dpi = 300
    qc_patch_count = 0
    qc_patch_size = 1024
    plain_csv = true
    export_qupath = false
    save_json = false
    log_level = 'INFO'
    allow_mixed_sampling = false
}

process {
    executor = 'local'
    container = params.container_image
    shell = ['/bin/bash', '-Eeuo', 'pipefail']
}

docker {
    enabled = false
    runOptions = "--shm-size=${params.docker_shm_size} ${params.docker_run_options ?: ''}".trim()
}

profiles {
    local {
        docker.enabled = false
        params.device = 'cpu'
        params.histoplus_cache_dir = "${System.getenv('HOME')}/.cache/lazyslide-histoplus/histoplus"
    }

    docker_cpu {
        docker.enabled = true
        params.container_image = 'carlosfarkas/lazyslide-histoplus@sha256:413bed6b55bc86923321c61453c18ece678da3c125ae44dcbd5f6c3bce7115d4'
        params.device = 'cpu'
        docker.runOptions = "--shm-size=${params.docker_shm_size} ${params.docker_run_options ?: ''}".trim()
    }

    docker_gpu {
        docker.enabled = true
        params.container_image = 'carlosfarkas/lazyslide-histoplus@sha256:c4b02485d4549a56348cd09995ce0788a6acc8a3e1e600e986b644231a95bd25'
        params.device = 'cuda'
        docker.runOptions = "--gpus all --shm-size=${params.docker_shm_size} ${params.docker_run_options ?: ''}".trim()
    }
}

report.overwrite = true
trace.overwrite = true
timeline.overwrite = true
dag.overwrite = true
